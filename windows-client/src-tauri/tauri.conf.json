{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "知识库",
  "version": "0.1.0",
  "identifier": "com.kb.knowledgebase",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "知识库",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "个人 AI 知识库",
    "longDescription": "自托管的个人知识库，支持 AI 对话、笔记管理、全文搜索。基于 RAG 技术，所有数据存储在你自己的设备上。"
  }
}
