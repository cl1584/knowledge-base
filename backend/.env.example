# 个人 AI 知识库 - 环境变量模板
# 复制本文件为 .env 并填入真实值：
#   cp .env.example .env
#
# 💡 提示：DEEPSEEK_API_KEY / DASHSCOPE_API_KEY 可以全部留空
#    启动后再到客户端「设置」页里填（推荐，更安全）
#    这里的值只是兜底（多用户共享一个 key 时才需要）

# === 基础配置 ===
APP_NAME=个人 AI 知识库
DEBUG=false

# === JWT 鉴权（必须改） ===
# 用 openssl rand -hex 32 生成
JWT_SECRET=change-me-please-use-openssl-rand-hex-32
JWT_EXPIRE_HOURS=720

# === DeepSeek（LLM，可选——客户端填更安全） ===
# 申请：https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# === DashScope（Embedding，可选）===
# 申请：https://dashscope.console.aliyun.com/apiKey
# 不配也能跑（走 numpy 兜底，但召回质量差）
DASHSCOPE_API_KEY=
EMBEDDING_MODEL=text-embedding-v2
EMBEDDING_DIM=1536

# === RAG 参数 ===
# chunk_size: 中文字符约 1 字/字，800-1000 适合笔记类长文
# chunk_overlap: 至少 10% 防止切断语义
CHUNK_SIZE=1000
CHUNK_OVERLAP=120
RETRIEVAL_TOP_K=8

# === CORS（生产环境必须改成具体域名） ===
# 例：https://kb.yourdomain.com
# 开发时用 http://localhost:5173
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:1420"]
